# Dependencies
node_modules/
**/node_modules/

# Env files — defence in depth.
# .env / .env.* covers root + nested files via gitignore's recursive default.
# The explicit per-directory entries below are NOT redundant: they survive
# even if someone (or a tool) adds a sub-folder .gitignore that re-includes
# .env files. Keep both.
.env
.env.*
!.env.example
mobile/.env
mobile/.env.*
!mobile/.env.example
web/.env
web/.env.*
!web/.env.example

# Local Supabase functions secrets
supabase/.env
supabase/functions/.env

# Vercel local dev secrets
.vercel/

# Credentials accidentally written by various tools
*credentials*.json
*service-account*.json
*-private.pem
*.pem
!*.example.pem

# Build output
dist/
build/
.next/
.expo/
.expo-shared/
mobile/.expo/
web/dist/
mobile/.expo/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.cursor/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Supabase
supabase/.branches
supabase/.temp
.vercel

# Edge function deploy bundles — generate only via:
#   node scripts/bundle-edge-function.mjs <fn> scripts/.deploy-<fn>.json
# Never use PowerShell Set-Content / ConvertTo-Json (corrupts UTF-8 em-dashes).
scripts/.bundle-*
scripts/.call-*
scripts/.deploy*
scripts/.invoke-*
scripts/.last-*
scripts/.mcp-*
scripts/.pipe-*
scripts/.result-*
scripts/.stdout-*
scripts/.tmp-*
scripts/.utf8-*
web/.env.vercel
web/.env.vercel.*

supabase/transfer/
