# ─────────────────────────────────────────────────────────────────────────
# VIGILANCE WEB DASHBOARD — ENVIRONMENT TEMPLATE
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` for local dev, or to `.env.production` for a
# local production build. NEVER commit a populated `.env` to git
# (.gitignore already enforces this).
#
# Vercel deployments do NOT read these files — set the same keys in the
# Vercel project's Environment Variables UI:
#     Project Settings → Environment Variables → Production / Preview
# Redeploy after editing values (env changes do not auto-trigger a build).
#
# Where to find the values:
#   1. Open https://supabase.com/dashboard/project/<project-ref>/settings/api
#   2. Copy "Project URL"            → VITE_SUPABASE_URL
#   3. Copy "anon" / "public" key    → VITE_SUPABASE_ANON_KEY
# Both keys are safe to ship to the browser; Row Level Security gates
# access. Never paste the `service_role` key into a VITE_ variable.
# ─────────────────────────────────────────────────────────────────────────

# Supabase REST + Realtime endpoint, e.g. https://abcd1234.supabase.co
VITE_SUPABASE_URL=

# Supabase anon (publishable) key — starts with `eyJ...`
VITE_SUPABASE_ANON_KEY=
